{
  "name": "nocodeflow",
  "version": "0.1.0",
  "description": "NoCodeFlow - AI-assisted no-code development platform",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:internal": "cross-env VITE_INTERNAL_BUILD=true vite build && electron-builder",
    "build:internal:win": "cross-env VITE_INTERNAL_BUILD=true vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:mac:arm64": "vite build && electron-builder --mac --arm64",
    "build:mac:x64": "vite build && electron-builder --mac --x64",
    "build:mac:ci": "gh workflow run build-mac.yml -f arch=both"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "electron-store": "^8.1.0",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "monaco-editor": "^0.55.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
